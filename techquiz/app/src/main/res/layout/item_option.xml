<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/option_row"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_option"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:clickable="true"
    android:focusable="true"
    android:paddingHorizontal="16dp"
    android:paddingVertical="15dp">

    <TextView
        android:id="@+id/option_key"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:background="@drawable/bg_key_default"
        android:gravity="center"
        android:includeFontPadding="false"
        android:textColor="@color/on_surface_var"
        android:textSize="14sp"
        android:textStyle="bold"
        tools:text="ア" />

    <TextView
        android:id="@+id/option_label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="14dp"
        android:lineSpacingMultiplier="1.4"
        android:textColor="@color/on_surface"
        android:textSize="15sp"
        android:fontFamily="sans-serif-medium"
        tools:text="ARP" />

    <ImageView
        android:id="@+id/option_tail"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_marginStart="10dp"
        android:visibility="gone"
        tools:src="@drawable/ic_check_circle"
        tools:visibility="visible"
        android:contentDescription="@null" />
</LinearLayout>
